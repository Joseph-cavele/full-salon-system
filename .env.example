# Copy this file to `.env` and fill in the values. Never commit your real `.env`.

# App — public base URL of the site
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB — Atlas connection string (Database > Connect > Drivers)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db-name>?appName=<app>

# Auth.js — session secret + canonical URL
# Generate a strong secret with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Cloudinary — image uploads (Dashboard > Settings > API Keys)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend — transactional email (https://resend.com/api-keys)
# Keep onboarding@resend.dev for local testing; use a verified-domain address in production.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Owner notification email (receives "new booking" emails)
OWNER_EMAIL=

# Password for the seeded dev accounts (owner@salon.test, jordan@salon.test).
# Used by `npm run seed`. Keep it out of source control.
SEED_PASSWORD=
